{
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "xoid": ["./packages/xoid/src"],
      "@xoid/devtools": ["./packages/devtools/src/devtools"],
      "xoid/*": ["./packages/xoid/src/*"],
      "@xoid/*": ["./packages/integrations/*/src"]
    },
    "target": "ES6",
    "jsx": "react-jsx",
    "downlevelIteration": true,
    "importHelpers": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationDir": "dist/ts-out",
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "strictNullChecks": true
  },
  "include": ["packages", "tests", "examples"],
  "exclude": ["packages/deprecated"]
}
